GEMINI_API_KEY = "your_gemini_api_key_here"

# Google Sheets (서비스 계정 JSON 필드 — 스프레드시트를 client_email 과 공유해야 함)
# 시트 탭: users (student_id, name, password_hash), history (아래 HISTORY 컬럼과 동일한 헤더 권장)
[connections.gsheets]
spreadsheet = "https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit"
type = "service_account"
project_id = ""
private_key_id = ""
private_key = ""
client_email = ""
client_id = ""
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = ""

# 학생 비밀번호 해시용 pepper (배포 시 반드시 임의 긴 문자열로 변경)
GSHEETS_PASSWORD_PEPPER = "change-this-to-a-long-random-secret"

